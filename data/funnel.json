  "automations": [
    {
      "id": "automation-mql-dql-short-credit-form",
      "name": "CRM Update — MQL / DQL (Short Credit Form Only)",
      "status": "mapped",
      "purpose": "Runs whenever a lead submits either short credit form. Reads the self-reported credit tier and routes the contact: below 640 clears MQL status and marks Marketing Disqualified Lead; 640 and above marks Marketing Qualified Lead with the submission date recorded. This is the single source of truth for whether a contact can continue toward booking a discovery call.",
      "overview": [
        "Trigger: Form submitted (either short credit form)",
        "   |",
        "   v",
        "IF credit score is \"Low: below 640\"",
        "   |",
        "   |- YES -> Remove MQL tag, add MDQL tag, clear MQL field",
        "   |          -> Set MQL = No, set DQ date, lifecycle = MDQL",
        "   |          -> End",
        "   |",
        "   '- NO  -> Remove MDQL tag, add MQL tag",
        "              -> Set lifecycle = Marketing Qualified Lead",
        "              -> Set MQL = Yes, set MQL submit date, MQL date",
        "              -> End"
      ],
      "treeId": "tree-mql-dql-short-credit-form"
    },
    {
      "id": "automation-lead-capture-follow-up-primary",
      "name": "Lead Capture Follow-Up Email — Primary",
      "status": "not-linked"
    }
  ],
